{
  "name": "@telekinesis/studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The Telekinesis Studio — an interactive, CapCut-style timesheet editor that introspects any Telekinetic app and renders GIFs/MP4s.",
  "bin": {
    "telekinesis-studio": "./server/bin.mjs"
  },
  "scripts": {
    "dev": "tsx server/index.ts",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@telekinesis/core": "workspace:*",
    "@telekinesis/schema": "workspace:*",
    "@xzdarcy/react-timeline-editor": "^1.0.0",
    "@xzdarcy/timeline-engine": "^1.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@telekinesis/engine": "workspace:*",
    "@telekinesis/render": "workspace:*",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}

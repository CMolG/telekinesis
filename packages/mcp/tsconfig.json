{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // DOM types are needed because this package compiles the engine's source,
    // whose page.evaluate callbacks reference `window`.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src"]
}

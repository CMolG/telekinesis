{
  "name": "@telekinesis/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Telekinesis — lets an LLM inspect a page's TelekineticFrames and draft a schema-valid timesheet.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "telekinesis-mcp": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@telekinesis/engine": "workspace:*",
    "@telekinesis/schema": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
